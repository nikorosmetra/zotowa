# Приватные ключи — НИКОГДА не коммитить
claude_key
*.pem
*.key
id_*

# Локальный контекст с доступами к серверу — не в публичный репозиторий
CLAUDE.md

# Внутренние черновики контента/спеки — не в публичный репозиторий
spec.md
content.md

# Рабочие ТЗ и личные документы (дипломы, фото) — не в публичный репозиторий
Переделать/
Документы ZOTOWA.RU/
Документы ZOTOWA.RU.zip

# Служебные файлы деплоя (создаются на сервере)
.deploy-paused

# Реальные файлы библиотеки документов (.docx) — загружаются на сервер вручную,
# не через git. Сами страницы /documents/*/index.html в репозитории остаются.
documents/*/*.docx

# Рабочая папка сборки библиотеки документов — не для публикации
_docs_build/

# Локальный мусор
.claude/
